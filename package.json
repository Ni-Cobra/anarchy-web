{
  "name": "anarchy-client",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "proto:gen": "mkdir -p src/gen && pbjs -t static-module -w es6 --es6 -o src/gen/anarchy.js proto/anarchy/v1/anarchy.proto && pbts -o src/gen/anarchy.d.ts src/gen/anarchy.js",
    "predev": "npm run proto:gen",
    "prebuild": "npm run proto:gen",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "protobufjs": "^7.4.0",
    "three": "^0.171.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/three": "^0.171.0",
    "protobufjs-cli": "^1.1.3",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^4.1.5"
  }
}
